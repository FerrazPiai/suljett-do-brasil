---
/**
 * Home — Página principal Suljett do Brasil
 *
 * Estrutura completa:
 * Header → Hero → SocialProof → CIJShowcase → HowItWorks →
 * ApplicationsGrid → OriginalVsParallel → ServicesStrip →
 * LeadMagnet → Testimonials → BlogPreview → Footer
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

// Seções Home
import Hero from '../components/home/Hero.astro';
import SocialProof from '../components/home/SocialProof.astro';
import CIJShowcase from '../components/home/CIJShowcase.astro';
import HowItWorks from '../components/home/HowItWorks.astro';
import ApplicationsGrid from '../components/home/ApplicationsGrid.astro';
import OriginalVsParallel from '../components/home/OriginalVsParallel.astro';
import ServicesStrip from '../components/home/ServicesStrip.astro';
import Testimonials from '../components/home/Testimonials.astro';
import BlogPreview from '../components/home/BlogPreview.astro';

// React Island — formulário de lead
import LeadMagnet from '../components/home/LeadMagnet.tsx';
---

<BaseLayout
  title="Impressoras CIJ Hitachi | Distribuidor Oficial Sul e Nordeste — Suljett do Brasil"
  description="Distribuidor Oficial Hitachi de impressoras CIJ para o Sul e Nordeste do Brasil. Insumos originais, assistência técnica 24h e garantia de 5 anos. 17 anos no mercado."
>
  <Header />

  <main id="main-content">

    <!-- 1. Hero — Fullscreen cinematográfico -->
    <Hero />

    <!-- 2. Social Proof — Contadores + logos -->
    <SocialProof />

    <!-- 3. CIJ Showcase — ★ Seção principal (300vh scroll storytelling) -->
    <CIJShowcase />

    <!-- 4. How It Works — 4 etapas com SVG animado -->
    <HowItWorks />

    <!-- 5. Applications Grid — 6 setores com hover expandido -->
    <ApplicationsGrid />

    <!-- 6. Original vs. Paralelo — Educação de mercado -->
    <OriginalVsParallel />

    <!-- 7. Services Strip — 4 pilares, fundo sj-red -->
    <ServicesStrip />

    <!-- 8. Lead Magnet — React Island (formulário + download) -->
    <section
      class="lead-magnet-section"
      aria-label="Download da ficha técnica CIJ Hitachi"
    >
      <div class="container">
        <div class="lead-magnet-inner">

          <!-- Conteúdo estático (Astro) -->
          <div class="lead-magnet-content">
            <div class="lead-magnet-icon" aria-hidden="true">
              <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
                <rect x="6" y="2" width="32" height="40" rx="3" stroke="#CC1A1A" stroke-width="2"/>
                <path d="M14 14h20M14 20h20M14 26h12" stroke="#CC1A1A" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M28 36l5 5 5-5" stroke="#CC1A1A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M33 41V30" stroke="#CC1A1A" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </div>

            <h2 class="lead-magnet-title">
              Baixe grátis: Ficha Técnica Comparativa
              da Linha CIJ Hitachi 2025
            </h2>

            <p class="lead-magnet-subtitle">
              Tabela completa com velocidade, resolução, viscosidade
              e consumo de tinta por modelo. Ideal para especificação
              técnica e comparação de fornecedores.
            </p>
          </div>

          <!-- React Island — formulário interativo -->
          <LeadMagnet client:visible />

        </div>
      </div>
    </section>

    <!-- 9. Testimonials — Embla Carousel -->
    <Testimonials />

    <!-- 10. Blog Preview — 3 artigos técnicos -->
    <BlogPreview />

  </main>

  <Footer />
</BaseLayout>

<style>
  /* ─── Lead Magnet Section ────────────────────────────────── */
  .lead-magnet-section {
    background-color: var(--steel-800);
    padding-block: var(--section-py-mobile);
    border-top: 1px solid var(--steel-700);
    border-bottom: 1px solid var(--steel-700);
  }

  @media (min-width: 768px) {
    .lead-magnet-section { padding-block: var(--section-py); }
  }

  .lead-magnet-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }

  @media (min-width: 1024px) {
    .lead-magnet-inner { grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
  }

  .lead-magnet-content {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .lead-magnet-icon {
    width: 64px;
    height: 64px;
    background: rgba(204, 26, 26, 0.08);
    border: 1px solid rgba(204, 26, 26, 0.2);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lead-magnet-title {
    font-size: var(--text-h2);
    font-weight: 700;
    color: var(--pure-white);
    line-height: 1.2;
  }

  .lead-magnet-subtitle {
    font-size: 1rem;
    color: var(--steel-300);
    line-height: 1.65;
    max-width: 440px;
  }

  /* ─── LeadMagnet React Component Styles ─────────────────── */
  :global(.lead-form) {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  :global(.lead-form-grid) {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    :global(.lead-form-grid) { grid-template-columns: repeat(2, 1fr); }
  }

  :global(.lead-field) {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  :global(.lead-label.spec) {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--steel-500);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  :global(.lead-input) {
    height: 44px;
    padding-inline: 1rem;
    background: var(--steel-900);
    border: 1px solid var(--steel-700);
    border-radius: 4px;
    color: var(--pure-white);
    font-family: var(--font-display);
    font-size: 0.9375rem;
    outline: none;
    transition:
      border-color var(--dur-micro) var(--ease-smooth),
      box-shadow var(--dur-micro) var(--ease-smooth);
    width: 100%;
  }

  :global(.lead-input::placeholder) { color: var(--steel-700); }

  :global(.lead-input:focus) {
    border-color: var(--sj-red);
    box-shadow: 0 0 0 3px rgba(204, 26, 26, 0.15);
  }

  :global(.lead-input.is-error) { border-color: #ef4444; }

  :global(.lead-select) {
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l5 5 5-5' stroke='%238DA0B8' stroke-width='1.5' stroke-linecap='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 1rem center;
    padding-right: 2.5rem;
    cursor: pointer;
  }

  :global(.lead-error.spec) {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: #ef4444;
    letter-spacing: 0.02em;
  }

  :global(.lead-submit-row) {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    align-items: flex-start;
  }

  :global(.lead-submit) {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--sj-red);
    color: var(--pure-white);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    padding: 0.75rem 1.5rem;
    border-radius: 4px;
    border: none;
    cursor: pointer;
    transition:
      background-color var(--dur-micro) var(--ease-mechanical),
      transform var(--dur-micro) var(--ease-mechanical),
      box-shadow var(--dur-micro) var(--ease-mechanical);
  }

  :global(.lead-submit:hover:not(:disabled)) {
    background: var(--sj-red-dark);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(204, 26, 26, 0.4);
  }

  :global(.lead-submit:disabled) {
    opacity: 0.7;
    cursor: not-allowed;
  }

  :global(.lead-spinner) {
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  :global(.lead-privacy.spec) {
    display: inline-flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--steel-700);
    line-height: 1.5;
    max-width: 380px;
  }

  :global(.lead-error-msg.spec) {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: #ef4444;
    padding: 0.75rem 1rem;
    background: rgba(239, 68, 68, 0.08);
    border: 1px solid rgba(239, 68, 68, 0.2);
    border-radius: 4px;
  }

  :global(.lead-success) {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
    padding: 2rem;
    background: rgba(34, 197, 94, 0.05);
    border: 1px solid rgba(34, 197, 94, 0.2);
    border-radius: 4px;
  }

  :global(.lead-success-title) {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: 700;
    color: var(--pure-white);
  }

  :global(.lead-success-text) {
    font-size: 0.9375rem;
    color: var(--steel-300);
    line-height: 1.6;
  }
</style>
