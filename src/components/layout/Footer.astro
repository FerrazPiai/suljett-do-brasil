---
/**
 * Footer — Completo com selos e links legais.
 * Fundo steel-950. Logo branca (flat).
 */

const currentYear = new Date().getFullYear();

const links = {
  products: [
    { label: 'CIJ Hitachi ★', href: '/produtos/cij' },
    { label: 'TIJ', href: '/produtos/tij' },
    { label: 'TTO', href: '/produtos/tto' },
    { label: 'Laser', href: '/produtos/laser' },
    { label: 'Insumos Originais', href: '/insumos' },
  ],
  services: [
    { label: 'Assistência Técnica', href: '/servicos/assistencia' },
    { label: 'Lab de Amostras', href: '/servicos/laboratorio' },
    { label: 'Treinamento', href: '/servicos/treinamento' },
    { label: 'Entrega de Insumos', href: '/insumos' },
  ],
  company: [
    { label: 'Sobre a Suljett', href: '/sobre' },
    { label: 'Blog Técnico', href: '/blog' },
    { label: 'Trabalhe Conosco', href: '/carreiras' },
    { label: 'Política de Privacidade', href: '/privacidade' },
    { label: 'Termos de Uso', href: '/termos' },
  ],
};
---

<footer class="site-footer theme-darker" role="contentinfo">
  <div class="container">

    <!-- Main Grid -->
    <div class="footer-grid">

      <!-- Brand -->
      <div class="footer-brand">
        <!-- Logo branca flat -->
        <a href="/" class="footer-logo" aria-label="Suljett do Brasil — Página inicial">
          <svg width="120" height="36" viewBox="0 0 120 36" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect width="8" height="36" rx="1" fill="#CC1A1A"/>
            <text x="16" y="26" font-family="Manrope, sans-serif" font-weight="800" font-size="22" fill="white">SULJETT</text>
          </svg>
        </a>

        <p class="footer-tagline">
          Distribuidor Oficial Hitachi para o Sul e Nordeste do Brasil.
          <br />
          Codificação industrial que nunca para.
        </p>

        <!-- Social links -->
        <div class="footer-social">
          <a
            href="https://wa.me/5554XXXXXXXX"
            class="footer-social-link"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="WhatsApp Suljett"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </a>

          <a
            href="https://linkedin.com/company/suljett"
            class="footer-social-link"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn Suljett"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>

        <!-- Contato -->
        <div class="footer-contact">
          <a href="tel:+5554XXXXXXXX" class="footer-contact-link spec">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M14.5 11.5l-3-1.5-1.5 1.5S7 10 6 9s-1.5-4-.5-4.5l1.5-1.5L5.5 1.5S4 1 3 2 1 6 1 6s1 5 4.5 8.5S12 15 12 15s2 0 3-2-.5-1.5-.5-1.5z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            (54) XXXX-XXXX
          </a>
          <a href="mailto:contato@suljett.com.br" class="footer-contact-link spec">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <rect x="1" y="3" width="14" height="10" rx="1" stroke="currentColor" stroke-width="1.2"/>
              <path d="M1 4l7 5 7-5" stroke="currentColor" stroke-width="1.2"/>
            </svg>
            contato@suljett.com.br
          </a>
        </div>
      </div>

      <!-- Links: Produtos -->
      <nav class="footer-nav" aria-label="Produtos">
        <h3 class="footer-nav-title spec">Produtos</h3>
        <ul role="list">
          {links.products.map((link) => (
            <li>
              <a href={link.href} class="footer-nav-link">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Links: Serviços -->
      <nav class="footer-nav" aria-label="Serviços">
        <h3 class="footer-nav-title spec">Serviços</h3>
        <ul role="list">
          {links.services.map((link) => (
            <li>
              <a href={link.href} class="footer-nav-link">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Links: Empresa -->
      <nav class="footer-nav" aria-label="Empresa">
        <h3 class="footer-nav-title spec">Empresa</h3>
        <ul role="list">
          {links.company.map((link) => (
            <li>
              <a href={link.href} class="footer-nav-link">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

    </div>

    <!-- Divider -->
    <div class="footer-divider" aria-hidden="true"></div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <!-- Selos de credencial -->
      <div class="footer-badges" aria-label="Certificações e selos">
        <div class="footer-badge">
          <span class="spec badge-label">ISO 9001</span>
        </div>
        <div class="footer-badge footer-badge--featured">
          <span class="spec badge-label">Distribuidor Oficial Hitachi</span>
        </div>
        <div class="footer-badge">
          <span class="spec badge-label">LGPD ✓</span>
        </div>
      </div>

      <p class="footer-copy spec">
        © {currentYear} Suljett do Brasil. Todos os direitos reservados.
      </p>
    </div>

  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--steel-950);
    padding-top: 5rem;
    padding-bottom: 2.5rem;
    border-top: 1px solid var(--steel-800);
  }

  /* ─── Grid Principal ─────────────────────────────────────── */
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    margin-bottom: 3rem;
  }

  @media (min-width: 768px) {
    .footer-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .footer-grid { grid-template-columns: 2fr 1fr 1fr 1fr; gap: 3rem; }
  }

  /* ─── Brand ──────────────────────────────────────────────── */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .footer-logo {
    display: inline-block;
    transition: opacity var(--dur-micro) var(--ease-smooth);
  }
  .footer-logo:hover { opacity: 0.8; }

  .footer-tagline {
    font-size: 0.9rem;
    color: var(--steel-500);
    line-height: 1.65;
    max-width: 300px;
  }

  .footer-social {
    display: flex;
    gap: 0.75rem;
  }

  .footer-social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 4px;
    background: var(--steel-800);
    color: var(--steel-300);
    border: 1px solid var(--steel-700);
    transition:
      background-color var(--dur-micro) var(--ease-smooth),
      color var(--dur-micro) var(--ease-smooth),
      border-color var(--dur-micro) var(--ease-smooth);
  }

  .footer-social-link:hover {
    background: var(--sj-red);
    color: var(--pure-white);
    border-color: var(--sj-red);
  }

  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-contact-link.spec {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--steel-500);
    transition: color var(--dur-micro) var(--ease-smooth);
  }

  .footer-contact-link.spec:hover { color: var(--pure-white); }

  /* ─── Nav Colunas ────────────────────────────────────────── */
  .footer-nav ul { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }

  .footer-nav-title.spec {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--steel-700);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }

  .footer-nav-link {
    font-size: 0.9rem;
    color: var(--steel-500);
    transition: color var(--dur-micro) var(--ease-smooth);
  }

  .footer-nav-link:hover { color: var(--pure-white); }

  /* ─── Divider ────────────────────────────────────────────── */
  .footer-divider {
    height: 1px;
    background: var(--steel-800);
    margin-bottom: 2rem;
  }

  /* ─── Bottom ─────────────────────────────────────────────── */
  .footer-bottom {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    align-items: flex-start;
  }

  @media (min-width: 768px) {
    .footer-bottom {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .footer-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .footer-badge {
    padding: 0.375rem 0.875rem;
    background: var(--steel-800);
    border: 1px solid var(--steel-700);
    border-radius: 2px;
  }

  .footer-badge--featured {
    border-color: rgba(204, 26, 26, 0.3);
    background: rgba(204, 26, 26, 0.05);
  }

  .badge-label.spec {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--steel-500);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .footer-badge--featured .badge-label.spec { color: rgba(204, 26, 26, 0.7); }

  .footer-copy.spec {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--steel-700);
  }
</style>
