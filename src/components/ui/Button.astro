---
/**
 * Button — Componente base de botões Suljett
 *
 * REGRAS INEGOCIÁVEIS:
 * - Primário: fundo sj-red, texto branco, border-radius 4px
 * - Hover: sj-red-dark + translateY(-2px) + sombra vermelha
 * - Sj-red SOMENTE em CTAs — nunca como fundo de seção
 */

export interface Props {
  variant?: 'primary' | 'secondary' | 'ghost' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
  class?: string;
  target?: '_blank' | '_self';
  rel?: string;
}

const {
  variant = 'primary',
  size = 'md',
  href,
  type = 'button',
  disabled = false,
  class: className = '',
  target,
  rel,
  ...attrs
} = Astro.props;

const baseClasses = [
  'inline-flex items-center justify-center gap-2',
  'font-display font-700 leading-none',
  'rounded-btn',           // border-radius: 4px — regra inegociável
  'transition-all',
  'duration-micro',
  'ease-mechanical',
  'cursor-pointer',
  'select-none',
  'whitespace-nowrap',
  'btn-primary',           // classe CSS com hover definido em animations.css
].join(' ');

const variants = {
  primary:   'bg-sj-red text-pure-white hover:bg-sj-red-dark active:bg-sj-red-dark',
  secondary: 'bg-steel-800 text-pure-white hover:bg-steel-700 border border-steel-700',
  ghost:     'bg-transparent text-pure-white hover:bg-steel-800/50 border border-steel-700',
  outline:   'bg-transparent text-sj-red border-2 border-sj-red hover:bg-sj-red hover:text-pure-white',
};

const sizes = {
  sm: 'h-9 px-4 text-sm',
  md: 'h-11 px-6 text-body',
  lg: 'h-13 px-8 text-h3',
};

const classes = [baseClasses, variants[variant], sizes[size], className].join(' ');
const Tag = href ? 'a' : 'button';
---

{href ? (
  <a
    href={href}
    target={target}
    rel={target === '_blank' ? (rel ?? 'noopener noreferrer') : rel}
    class={classes}
    {...attrs}
  >
    <slot />
  </a>
) : (
  <button
    type={type}
    disabled={disabled}
    class={[classes, disabled ? 'opacity-50 cursor-not-allowed pointer-events-none' : ''].join(' ')}
    {...attrs}
  >
    <slot />
  </button>
)}

<style>
  /* Arrow icon no botão primário */
  :global(.btn-arrow) {
    display: inline-block;
    transition: transform var(--dur-micro) var(--ease-mechanical);
  }

  a:hover :global(.btn-arrow),
  button:hover :global(.btn-arrow) {
    transform: translateX(4px);
  }
</style>
