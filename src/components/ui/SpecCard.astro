---
/**
 * SpecCard — Card de especificação técnica
 *
 * REGRA INEGOCIÁVEL: labels em IBM Plex Mono, valores em Manrope.
 * Usado em CIJShowcase, fichas de produto, comparativo.
 */

export interface Props {
  label: string;
  value: string;
  unit?: string;
  description?: string;
  class?: string;
}

const {
  label,
  value,
  unit = '',
  description = '',
  class: className = '',
} = Astro.props;
---

<div
  class:list={[
    'spec-item',
    'group',
    'flex flex-col gap-1',
    'p-5 rounded-sm',
    'border border-steel-700',
    'bg-steel-800/50',
    'hover:border-sj-red/40 hover:bg-steel-800',
    'transition-colors duration-short ease-mechanical',
    className,
  ]}
>
  <!-- Label: IBM Plex Mono — OBRIGATÓRIO -->
  <span class="spec text-mono-spec text-steel-300 uppercase tracking-widest">
    {label}
  </span>

  <!-- Valor: Manrope Bold -->
  <div class="flex items-baseline gap-2 mt-1">
    <span class="font-display font-800 text-h3 text-pure-white leading-tight">
      {value}
    </span>
    {unit && (
      <span class="spec text-mono-spec text-steel-500">
        {unit}
      </span>
    )}
  </div>

  <!-- Descrição opcional -->
  {description && (
    <p class="text-sm text-steel-500 mt-1 leading-relaxed">
      {description}
    </p>
  )}

  <!-- Linha de acento -->
  <div
    class="h-px w-0 bg-sj-red mt-2 transition-all duration-short ease-mechanical group-hover:w-full"
    aria-hidden="true"
  />
</div>
