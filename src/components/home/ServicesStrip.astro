---
/**
 * ServicesStrip — 4 Pilares de Serviço
 * Fundo sj-red. 4 cards horizontais.
 *
 * REGRA: sj-red APENAS em CTAs e elementos de destaque — NUNCA fundo de seções.
 * EXCEÇÃO ÚNICA: Esta strip tem fundo sj-red por decisão de design para criar
 * contraste e urgência visual entre seções escuras e claras.
 */

const services = [
  {
    icon: 'wrench',
    title: 'Assistência Técnica 24h',
    description: 'Suporte remoto e presencial. Técnicos certificados Hitachi.',
    link: '/servicos/assistencia',
  },
  {
    icon: 'flask',
    title: 'Laboratório de Amostras',
    description: 'Teste gratuito de impressão na sua embalagem antes de comprar.',
    link: '/servicos/laboratorio',
  },
  {
    icon: 'package',
    title: 'Entrega Rápida de Insumos',
    description: 'Estoque permanente. Entrega expressa Sul e Nordeste.',
    link: '/insumos',
  },
  {
    icon: 'graduation-cap',
    title: 'Treinamento Técnico',
    description: 'Capacitação da sua equipe para operação e manutenção preventiva.',
    link: '/servicos/treinamento',
  },
];
---

<section
  class="services-strip"
  aria-label="Pilares de serviço Suljett"
>
  <div class="container">
    <div class="services-grid" role="list">

      {services.map((service) => (
        <a
          href={service.link}
          class="service-card"
          role="listitem"
          aria-label={service.title}
        >
          <!-- Ícone (SVG placeholder por Lucide) -->
          <div class="service-icon" aria-hidden="true">
            {service.icon === 'wrench' && (
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/>
              </svg>
            )}
            {service.icon === 'flask' && (
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 3h6M9 3v8l-4 9h14l-4-9V3"/>
              </svg>
            )}
            {service.icon === 'package' && (
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16.5 9.4l-9-5.19M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/>
                <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
                <line x1="12" y1="22.08" x2="12" y2="12"/>
              </svg>
            )}
            {service.icon === 'graduation-cap' && (
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
                <path d="M6 12v5c3 3 9 3 12 0v-5"/>
              </svg>
            )}
          </div>

          <div class="service-body">
            <h3 class="service-title">{service.title}</h3>
            <p class="service-description">{service.description}</p>
          </div>

          <div class="service-arrow" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 10h12M12 6l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </a>
      ))}

    </div>
  </div>
</section>

<style>
  .services-strip {
    background-color: var(--sj-red);
    padding-block: 4rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background-color: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 4px;
    overflow: hidden;
  }

  @media (min-width: 640px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .services-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .service-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 2rem 1.75rem;
    background-color: var(--sj-red);
    transition: background-color var(--dur-short) var(--ease-mechanical);
    position: relative;
  }

  .service-card:hover {
    background-color: var(--sj-red-dark);
  }

  .service-icon {
    color: rgba(255, 255, 255, 0.85);
    flex-shrink: 0;
  }

  .service-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .service-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--pure-white);
    line-height: 1.3;
  }

  .service-description {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.55;
  }

  .service-arrow {
    color: rgba(255, 255, 255, 0.5);
    margin-top: auto;
    align-self: flex-start;
    transition:
      transform var(--dur-micro) var(--ease-mechanical),
      color var(--dur-micro) var(--ease-mechanical);
  }

  .service-card:hover .service-arrow {
    transform: translateX(6px);
    color: var(--pure-white);
  }
</style>
