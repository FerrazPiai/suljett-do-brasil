---
/**
 * OriginalVsParallel — Hitachi Original vs. Paralelo
 * Seção de educação de mercado. Fundo steel-900.
 * As duas colunas entram de lados opostos via GSAP.
 */

const originalFeatures = [
  'Fórmula certificada pelo fabricante Hitachi',
  'Garantia de 5 anos da máquina mantida',
  'Código S10 legítimo — rastreável',
  'Suporte técnico Suljett 24h',
  'Viscosidade calibrada para a máquina',
  'Aprovação ANVISA para alimentos',
];

const parallelRisks = [
  'Composição química desconhecida',
  'Anula a garantia da impressora',
  '"Código S10" falso no rótulo',
  'Sem suporte técnico especializado',
  'Entupimento do bico de impressão',
  'Risco de contaminação alimentar',
];
---

<section
  class="competitor-section section theme-dark"
  aria-label="Insumos Originais Hitachi versus Paralelos"
>
  <div class="container">

    <header class="competitor-header">
      <span class="spec competitor-label">Educação de Mercado</span>
      <h2 class="competitor-title">
        Insumo original ou paralelo?<br />
        O que está em jogo.
      </h2>
      <p class="competitor-subtitle">
        Tinta não-original causa falhas silenciosas que destroem impressoras e
        interrompem linhas de produção. Entenda a diferença.
      </p>
    </header>

    <div class="comparison-grid">

      <!-- Coluna: ORIGINAL ✅ -->
      <div class="original-col comparison-col comparison-col--positive">
        <div class="col-header">
          <div class="col-badge col-badge--positive" aria-hidden="true">✅</div>
          <div>
            <span class="spec col-type">Insumos</span>
            <h3 class="col-title">Originais Hitachi</h3>
          </div>
        </div>

        <ul class="features-list" role="list">
          {originalFeatures.map((feature) => (
            <li class="feature-item feature-item--positive" role="listitem">
              <svg class="feature-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8l4 4 6-7" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span>{feature}</span>
            </li>
          ))}
        </ul>

        <div class="col-cta">
          <a href="/insumos" class="btn-original">
            Comprar Insumo Original
            <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Divisor -->
      <div class="comparison-vs" aria-hidden="true">
        <span class="vs-text spec">VS</span>
      </div>

      <!-- Coluna: PARALELO ❌ -->
      <div class="parallel-col comparison-col comparison-col--negative">
        <div class="col-header">
          <div class="col-badge col-badge--negative" aria-hidden="true">❌</div>
          <div>
            <span class="spec col-type">Insumos</span>
            <h3 class="col-title col-title--negative">Paralelos (imitações)</h3>
          </div>
        </div>

        <ul class="features-list" role="list">
          {parallelRisks.map((risk) => (
            <li class="feature-item feature-item--negative" role="listitem">
              <svg class="feature-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 4l8 8M12 4l-8 8" stroke="#ef4444" stroke-width="2" stroke-linecap="round"/>
              </svg>
              <span>{risk}</span>
            </li>
          ))}
        </ul>

        <div class="parallel-warning">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <path d="M9 1l8 15H1L9 1z" stroke="#ef4444" stroke-width="1.5"/>
            <path d="M9 7v4M9 13v.5" stroke="#ef4444" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <p class="spec warning-text">
            Insumos paralelos já causaram interdições sanitárias e perda de garantia de equipamentos no valor de R$ 120.000+.
          </p>
        </div>
      </div>

    </div>

  </div>
</section>

<style>
  /* ─── Header ─────────────────────────────────────────────── */
  .competitor-header {
    text-align: center;
    max-width: 600px;
    margin-inline: auto;
    margin-bottom: 4rem;
  }

  .competitor-label.spec {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--steel-500);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 0.875rem;
  }

  .competitor-title {
    font-size: var(--text-h2);
    font-weight: 700;
    color: var(--pure-white);
    line-height: 1.15;
    margin-bottom: 1rem;
  }

  .competitor-subtitle {
    color: var(--steel-300);
    font-size: 1.0625rem;
    line-height: 1.65;
  }

  /* ─── Grid ───────────────────────────────────────────────── */
  .comparison-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: start;
  }

  @media (min-width: 1024px) {
    .comparison-grid {
      grid-template-columns: 1fr auto 1fr;
      gap: 2.5rem;
      align-items: stretch;
    }
  }

  /* ─── Colunas ────────────────────────────────────────────── */
  .comparison-col {
    padding: 2rem;
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .comparison-col--positive {
    background: rgba(34, 197, 94, 0.05);
    border: 1px solid rgba(34, 197, 94, 0.2);
  }

  .comparison-col--negative {
    background: rgba(239, 68, 68, 0.05);
    border: 1px solid rgba(239, 68, 68, 0.15);
  }

  /* Cabeçalho da coluna */
  .col-header {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .col-badge {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    flex-shrink: 0;
  }

  .col-badge--positive { background: rgba(34, 197, 94, 0.1); }
  .col-badge--negative { background: rgba(239, 68, 68, 0.1); }

  .col-type.spec {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--steel-500);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 3px;
  }

  .col-title {
    font-size: var(--text-h3);
    font-weight: 700;
    color: var(--pure-white);
  }

  .col-title--negative { color: rgba(239, 68, 68, 0.9); }

  /* Lista de features */
  .features-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    flex: 1;
  }

  .feature-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.9375rem;
    line-height: 1.5;
  }

  .feature-item--positive { color: var(--steel-300); }
  .feature-item--negative { color: var(--steel-500); }

  .feature-icon {
    flex-shrink: 0;
    margin-top: 2px;
  }

  /* CTA original */
  .col-cta { margin-top: auto; }

  .btn-original {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--sj-red);
    color: var(--pure-white);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9375rem;
    padding: 0.75rem 1.25rem;
    border-radius: 4px;
    transition:
      background-color var(--dur-micro) var(--ease-mechanical),
      transform var(--dur-micro) var(--ease-mechanical),
      box-shadow var(--dur-micro) var(--ease-mechanical);
  }

  .btn-original:hover {
    background: var(--sj-red-dark);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(204, 26, 26, 0.4);
  }

  .btn-original .btn-arrow {
    transition: transform var(--dur-micro) var(--ease-mechanical);
  }

  .btn-original:hover .btn-arrow { transform: translateX(4px); }

  /* Warning paralelo */
  .parallel-warning {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1rem;
    background: rgba(239, 68, 68, 0.08);
    border: 1px solid rgba(239, 68, 68, 0.2);
    border-radius: 4px;
    margin-top: auto;
  }

  .warning-text.spec {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: rgba(239, 68, 68, 0.7);
    line-height: 1.5;
    letter-spacing: 0.02em;
  }

  /* VS Divisor */
  .comparison-vs {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
  }

  .vs-text.spec {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 500;
    color: var(--steel-700);
    letter-spacing: 0.1em;
  }

  @media (min-width: 1024px) {
    .comparison-vs {
      padding: 0;
      align-items: center;
    }
  }
</style>
