---
/**
 * Testimonials — Depoimentos com Embla Carousel
 * Fotos reais de instalação + depoimento do responsável técnico.
 */

const testimonials = [
  {
    quote: 'A impressora Hitachi UX-D160W rodando há 3 anos na nossa linha, zero paradas não programadas. A assistência da Suljett é diferenciada — resolvem no mesmo dia.',
    author: 'Carlos Eduardo',
    role: 'Supervisor de Produção',
    company: 'Frigorífico Sul Ltda',
    sector: 'Alimentícia',
    since: '2021',
    machines: 4,
    photo: '/assets/testimonials/carlos-eduardo.jpg',
    machinePhoto: '/assets/testimonials/instalacao-frigorifico.jpg',
  },
  {
    quote: 'Antes usávamos insumo paralelo e a impressora travou em plena linha. Com o insumo original Hitachi via Suljett, resolvemos o problema e nunca mais tivemos avaria.',
    author: 'Mariana Santos',
    role: 'Engenheira de Qualidade',
    company: 'Laticínios Pioneiro',
    sector: 'Laticínios',
    since: '2022',
    machines: 2,
    photo: '/assets/testimonials/mariana-santos.jpg',
    machinePhoto: '/assets/testimonials/instalacao-laticinios.jpg',
  },
  {
    quote: 'O laboratório de amostras da Suljett foi decisivo. Testamos a impressão nas nossas embalagens antes de fechar o contrato. Profissionalismo em cada etapa.',
    author: 'Roberto Machado',
    role: 'Diretor Industrial',
    company: 'Bebidas Gaúcha S.A.',
    sector: 'Bebidas',
    since: '2020',
    machines: 7,
    photo: '/assets/testimonials/roberto-machado.jpg',
    machinePhoto: '/assets/testimonials/instalacao-bebidas.jpg',
  },
];
---

<section
  class="testimonials section theme-white"
  aria-label="Depoimentos de clientes"
>
  <div class="container">

    <header class="testimonials-header">
      <span class="spec test-label">Cases Reais</span>
      <h2 class="test-title">O que nossos clientes dizem</h2>
    </header>

    <!-- Carousel -->
    <div class="embla testimonials-carousel" role="region" aria-label="Carrossel de depoimentos" aria-roledescription="carousel">
      <div class="embla__container">
        {testimonials.map((t, i) => (
          <article
            class="embla__slide testimonial-card"
            role="group"
            aria-roledescription="slide"
            aria-label={`Depoimento ${i + 1} de ${testimonials.length}`}
          >
            <!-- Foto da instalação -->
            <div class="testimonial-machine-img" aria-hidden="true">
              <div class="machine-img-placeholder"></div>
              <div class="machine-img-overlay" aria-hidden="true"></div>
              <span class="spec machine-sector-label">{t.sector}</span>
            </div>

            <!-- Conteúdo do depoimento -->
            <div class="testimonial-body">
              <!-- Quote mark decorativo -->
              <svg class="quote-mark" aria-hidden="true" width="32" height="24" viewBox="0 0 32 24" fill="none">
                <path d="M13 0H0v14h6l-3 10h6L13 0zm19 0H19v14h6l-3 10h6L32 0z" fill="#CC1A1A" opacity="0.15"/>
              </svg>

              <blockquote class="testimonial-quote">
                "{t.quote}"
              </blockquote>

              <footer class="testimonial-footer">
                <!-- Avatar -->
                <div class="testimonial-avatar" aria-hidden="true">
                  <div class="avatar-placeholder">
                    {t.author.charAt(0)}
                  </div>
                </div>

                <div class="testimonial-meta">
                  <cite class="testimonial-author">{t.author}</cite>
                  <span class="spec testimonial-role">{t.role} · {t.company}</span>
                </div>

                <!-- Stats -->
                <div class="testimonial-stats">
                  <div class="testimonial-stat">
                    <span class="spec stat-value">{t.machines}</span>
                    <span class="spec stat-label">máquinas</span>
                  </div>
                  <div class="testimonial-stat">
                    <span class="spec stat-value">Desde {t.since}</span>
                    <span class="spec stat-label">cliente</span>
                  </div>
                </div>
              </footer>
            </div>
          </article>
        ))}
      </div>

      <!-- Dots Navigation -->
      <div class="carousel-dots" role="tablist" aria-label="Navegação dos depoimentos">
        {testimonials.map((_, i) => (
          <button
            class={`carousel-dot ${i === 0 ? 'is-active' : ''}`}
            role="tab"
            aria-label={`Ir para depoimento ${i + 1}`}
            aria-selected={i === 0 ? 'true' : 'false'}
            data-index={i}
          />
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  /* ─── Header ─────────────────────────────────────────────── */
  .testimonials-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .test-label.spec {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--sj-red);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 0.75rem;
  }

  .test-title {
    font-size: var(--text-h2);
    font-weight: 700;
    color: var(--ink-950);
    line-height: 1.15;
  }

  /* ─── Carousel ───────────────────────────────────────────── */
  .embla { overflow: hidden; }
  .embla__container {
    display: flex;
    gap: 1.5rem;
  }

  .embla__slide.testimonial-card {
    flex: 0 0 100%;
    min-width: 0;
  }

  @media (min-width: 1024px) {
    .embla__slide.testimonial-card { flex: 0 0 calc(50% - 0.75rem); }
  }

  /* ─── Card ───────────────────────────────────────────────── */
  .testimonial-card {
    display: flex;
    flex-direction: column;
    background: var(--steel-50);
    border: 1px solid var(--steel-100);
    border-radius: 4px;
    overflow: hidden;
    transition:
      border-color var(--dur-short) var(--ease-mechanical),
      box-shadow var(--dur-short) var(--ease-mechanical);
  }

  .testimonial-card:hover {
    border-color: var(--sj-red);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
  }

  /* Foto da máquina */
  .testimonial-machine-img {
    position: relative;
    height: 200px;
    overflow: hidden;
  }

  .machine-img-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--steel-800), var(--steel-900));
    transition: transform var(--dur-medium) var(--ease-mechanical);
  }

  .testimonial-card:hover .machine-img-placeholder {
    transform: scale(1.04);
  }

  .machine-img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(10, 15, 26, 0.6), transparent);
  }

  .machine-sector-label.spec {
    position: absolute;
    top: 1rem;
    left: 1rem;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--pure-white);
    background: rgba(10, 15, 26, 0.7);
    padding: 0.25rem 0.625rem;
    border-radius: 2px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    backdrop-filter: blur(4px);
  }

  /* Corpo do depoimento */
  .testimonial-body {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    flex: 1;
  }

  .quote-mark {
    flex-shrink: 0;
  }

  .testimonial-quote {
    font-size: 0.9375rem;
    color: var(--ink-600);
    line-height: 1.7;
    font-style: normal;
    flex: 1;
  }

  /* Footer do card */
  .testimonial-footer {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--steel-100);
    flex-wrap: wrap;
  }

  .testimonial-avatar { flex-shrink: 0; }

  .avatar-placeholder {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--sj-red);
    color: var(--pure-white);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.125rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .testimonial-meta {
    flex: 1;
    min-width: 0;
  }

  .testimonial-author {
    display: block;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9375rem;
    color: var(--ink-950);
    font-style: normal;
  }

  .testimonial-role.spec {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--steel-500);
    margin-top: 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Stats */
  .testimonial-stats {
    display: flex;
    gap: 1rem;
    flex-shrink: 0;
  }

  .testimonial-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1px;
  }

  .stat-value.spec {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ink-950);
  }

  .stat-label.spec {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--steel-300);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* ─── Dots ───────────────────────────────────────────────── */
  .carousel-dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 2rem;
  }

  .carousel-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--steel-100);
    border: none;
    cursor: pointer;
    padding: 0;
    transition:
      background-color var(--dur-short) var(--ease-mechanical),
      transform var(--dur-short) var(--ease-mechanical);
  }

  .carousel-dot.is-active {
    background: var(--sj-red);
    transform: scale(1.25);
  }
</style>

<script>
  import EmblaCarousel from 'embla-carousel';
  import Autoplay from 'embla-carousel-autoplay';

  const carouselEl = document.querySelector('.testimonials-carousel');
  if (carouselEl) {
    const embla = EmblaCarousel(
      carouselEl,
      { loop: true, align: 'start' },
      [Autoplay({ delay: 4000, stopOnInteraction: true, stopOnMouseEnter: true })]
    );

    // Dots
    const dots = document.querySelectorAll('.carousel-dot');

    const updateDots = () => {
      const index = embla.selectedScrollSnap();
      dots.forEach((dot, i) => {
        const isActive = i === index;
        dot.classList.toggle('is-active', isActive);
        dot.setAttribute('aria-selected', String(isActive));
      });
    };

    embla.on('select', updateDots);

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => embla.scrollTo(i));
    });
  }
</script>
