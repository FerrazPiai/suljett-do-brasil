---
/**
 * HowItWorks — Como a CIJ funciona
 * 4 etapas com linha SVG animada via stroke-dashoffset + ScrollTrigger.
 */

const steps = [
  {
    number: '01',
    title: 'Tinta Pressurizada',
    description: 'O sistema bombeia tinta a alta pressão, criando um fluxo contínuo e estável através do bico de impressão.',
    icon: 'droplet',
  },
  {
    number: '02',
    title: 'Gota por Vibração Piezo',
    description: 'Cristais piezoelétricos vibram em frequências precisas, fragmentando o jato em gotículas uniformes de micrômetros.',
    icon: 'zap',
  },
  {
    number: '03',
    title: 'Campo Elétrico Deflete a Gota',
    description: 'Cada gota recebe carga elétrica individual. Placas de deflexão direcionam cada uma ao ponto exato na superfície.',
    icon: 'magnet',
  },
  {
    number: '04',
    title: 'Marca Perfeita na Embalagem',
    description: 'Resultado: código de validade, lote, QR code ou texto nítido sobre qualquer superfície — a 18.000 impressões/hora.',
    icon: 'check-circle',
  },
];
---

<section
  class="how-it-works section theme-light"
  aria-label="Como funciona a impressora CIJ"
>
  <div class="container">

    <header class="hiw-header">
      <span class="spec hiw-label">Tecnologia CIJ</span>
      <h2 class="hiw-title">Como a codificação contínua funciona</h2>
      <p class="hiw-subtitle">
        Da pressão da tinta à marca perfeita na embalagem —
        em milissegundos.
      </p>
    </header>

    <!-- Steps container -->
    <div class="steps-container">

      <!-- SVG Connecting Line (animada por GSAP scroll) -->
      <svg
        class="process-svg"
        aria-hidden="true"
        viewBox="0 0 1200 60"
        preserveAspectRatio="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          class="process-line"
          d="M 150 30 L 1050 30"
          stroke="#CC1A1A"
          stroke-width="1.5"
          stroke-dasharray="1000"
          stroke-dashoffset="1000"
          fill="none"
          stroke-linecap="round"
        />
        <!-- Pontos nos steps -->
        <circle cx="150"  cy="30" r="5" fill="#CC1A1A" opacity="0"/>
        <circle cx="516"  cy="30" r="5" fill="#CC1A1A" opacity="0"/>
        <circle cx="784"  cy="30" r="5" fill="#CC1A1A" opacity="0"/>
        <circle cx="1050" cy="30" r="5" fill="#CC1A1A" opacity="0"/>
      </svg>

      <!-- Steps Grid -->
      <div class="steps-grid" role="list">
        {steps.map((step, i) => (
          <article
            class="process-step"
            role="listitem"
            aria-label={`Etapa ${step.number}: ${step.title}`}
          >
            <!-- Número da etapa -->
            <div class="step-number-wrapper">
              <div class="step-circle" aria-hidden="true">
                <span class="spec step-num">{step.number}</span>
              </div>
            </div>

            <!-- Conteúdo -->
            <div class="step-body">
              <h3 class="step-title">{step.title}</h3>
              <p class="step-description">{step.description}</p>
            </div>

            {/* Seta conectora (exceto no último) */}
            {i < steps.length - 1 && (
              <div class="step-arrow" aria-hidden="true">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                  <path d="M5 12h14M15 8l4 4-4 4" stroke="#CC1A1A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            )}
          </article>
        ))}
      </div>

    </div>

    <!-- CTA ao fim -->
    <div class="hiw-cta">
      <a href="/blog/como-funciona-impressora-cij" class="hiw-cta-link">
        Leia o guia técnico completo
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<style>
  /* ─── Header ─────────────────────────────────────────────── */
  .hiw-header {
    text-align: center;
    margin-bottom: 4rem;
    max-width: 580px;
    margin-inline: auto;
  }

  .hiw-label.spec {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--sj-red);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 0.875rem;
  }

  .hiw-title {
    font-size: var(--text-h2);
    font-weight: 700;
    color: var(--ink-950);
    line-height: 1.15;
    margin-bottom: 0.875rem;
  }

  .hiw-subtitle {
    color: var(--steel-500);
    font-size: 1.0625rem;
    line-height: 1.6;
  }

  /* ─── Steps Container ────────────────────────────────────── */
  .steps-container {
    position: relative;
  }

  /* SVG line — só desktop */
  .process-svg {
    display: none;
    width: 100%;
    height: 60px;
    margin-bottom: -30px;
    position: relative;
    z-index: 1;
  }

  @media (min-width: 1024px) {
    .process-svg { display: block; }
  }

  .process-line {
    stroke-dasharray: 1000;
    stroke-dashoffset: 1000;
    /* GSAP ScrollTrigger anima stroke-dashoffset → 0 */
  }

  /* ─── Steps Grid ─────────────────────────────────────────── */
  .steps-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    position: relative;
    z-index: 2;
  }

  @media (min-width: 768px) {
    .steps-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .steps-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .process-step {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: relative;
    padding: 1.75rem 1.5rem;
    background: var(--pure-white);
    border: 1px solid var(--steel-100);
    border-radius: 4px;
    transition:
      border-color var(--dur-short) var(--ease-mechanical),
      box-shadow var(--dur-short) var(--ease-mechanical);
  }

  .process-step:hover {
    border-color: var(--sj-red);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  /* Seta conectora (desktop only) */
  .step-arrow {
    display: none;
    position: absolute;
    right: -20px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
  }

  @media (min-width: 1024px) {
    .step-arrow { display: block; }
  }

  /* Círculo de número */
  .step-number-wrapper {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .step-circle {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 1.5px solid var(--sj-red);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    background: rgba(204, 26, 26, 0.05);
  }

  .step-num.spec {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--sj-red);
    letter-spacing: 0.05em;
  }

  /* Conteúdo */
  .step-title {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--ink-950);
    line-height: 1.3;
  }

  .step-description {
    font-size: 0.9375rem;
    color: var(--ink-600);
    line-height: 1.6;
  }

  /* ─── CTA ────────────────────────────────────────────────── */
  .hiw-cta {
    text-align: center;
    margin-top: 3rem;
  }

  .hiw-cta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--sj-red);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.9375rem;
    transition:
      gap var(--dur-micro) var(--ease-mechanical),
      color var(--dur-micro) var(--ease-mechanical);
  }

  .hiw-cta-link:hover {
    color: var(--sj-red-dark);
    gap: 0.75rem;
  }
</style>
