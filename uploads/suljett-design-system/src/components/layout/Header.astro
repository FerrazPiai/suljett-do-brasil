---
/**
 * Header — Sticky com glassmorphism ao scroll
 *
 * Comportamento:
 * - Inicial: position absolute, fundo transparente
 * - Após 80px scroll: fixed, backdrop-blur, steel-950/90
 * - Transição gerenciada via Lenis em lenis.js
 *
 * Dropdown: clip-path top → bottom, 0.35s, ease mechanical
 */
---

<header class="site-header" role="banner">
  <div class="container">
    <nav class="nav-inner" aria-label="Navegação principal">

      <!-- Logo -->
      <a href="/" class="logo" aria-label="Suljett do Brasil — Página inicial">
        <!-- SVG Logo: versão flat (simplificada) para fundos escuros -->
        <svg
          width="120"
          height="36"
          viewBox="0 0 120 36"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <!-- Placeholder: substitua pelo SVG real do logo Suljett -->
          <rect width="8" height="36" rx="1" fill="#CC1A1A"/>
          <text
            x="16"
            y="26"
            font-family="Manrope, sans-serif"
            font-weight="800"
            font-size="22"
            fill="white"
          >SULJETT</text>
        </svg>
      </a>

      <!-- Nav Links Desktop -->
      <ul class="nav-links" role="list">
        <li>
          <a href="/sobre" class="nav-link">Sobre</a>
        </li>

        <!-- Produtos — Mega Menu -->
        <li class="has-dropdown">
          <button
            class="nav-link nav-link--dropdown"
            aria-haspopup="true"
            aria-expanded="false"
            aria-controls="mega-menu-produtos"
          >
            Produtos
            <svg class="dropdown-chevron" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          <!-- Mega Menu -->
          <div
            id="mega-menu-produtos"
            class="mega-menu dropdown-enter"
            role="dialog"
            aria-label="Menu de Produtos"
          >
            <div class="mega-menu-inner">

              <!-- Destaque: CIJ -->
              <div class="mega-menu-featured">
                <a href="/produtos/cij" class="mega-menu-cij">
                  <span class="mega-menu-star" aria-hidden="true">★</span>
                  <div>
                    <strong>CIJ — Impressora a Jato de Tinta Contínuo</strong>
                    <span class="mega-menu-models">
                      Hitachi UX-D160W &nbsp;|&nbsp; UX-D150W &nbsp;|&nbsp; PX-D series
                    </span>
                  </div>
                </a>
              </div>

              <!-- Grade de categorias -->
              <div class="mega-menu-grid">
                <a href="/produtos/tij" class="mega-menu-item">
                  <strong>TIJ</strong>
                  <span>Jato de Tinta Termal</span>
                </a>
                <a href="/produtos/tto" class="mega-menu-item">
                  <strong>TTO</strong>
                  <span>Transferência Térmica</span>
                </a>
                <a href="/produtos/laser" class="mega-menu-item">
                  <strong>Laser</strong>
                  <span>Marcação a Laser</span>
                </a>
                <a href="/produtos/gch" class="mega-menu-item">
                  <strong>GCH</strong>
                  <span>Grandes Caracteres</span>
                </a>
                <a href="/insumos" class="mega-menu-item">
                  <strong>Insumos Originais</strong>
                  <span>Hitachi Certificados</span>
                </a>
                <a href="/comparador" class="mega-menu-item mega-menu-item--accent">
                  <strong>Comparador Técnico</strong>
                  <span>Compare modelos →</span>
                </a>
              </div>

            </div>
          </div>
        </li>

        <li><a href="/servicos" class="nav-link">Serviços</a></li>
        <li><a href="/aplicacoes" class="nav-link">Aplicações</a></li>
        <li><a href="/blog" class="nav-link">Blog</a></li>
      </ul>

      <!-- Ações direita -->
      <div class="nav-actions">
        <button class="btn-search" aria-label="Buscar">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="9" cy="9" r="6" stroke="currentColor" stroke-width="1.5"/>
            <path d="M15 15l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>

        <a href="/contato#orcamento" class="btn-cta">
          Solicitar Orçamento
          <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>

        <!-- Menu hamburger mobile -->
        <button class="btn-hamburger" aria-label="Abrir menu" aria-expanded="false" aria-controls="mobile-menu">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="mobile-menu" aria-hidden="true" role="dialog" aria-label="Menu mobile">
    <nav>
      <ul role="list">
        <li><a href="/sobre">Sobre</a></li>
        <li><a href="/produtos/cij">CIJ Hitachi ★</a></li>
        <li><a href="/produtos/tij">TIJ</a></li>
        <li><a href="/produtos/tto">TTO</a></li>
        <li><a href="/produtos/laser">Laser</a></li>
        <li><a href="/servicos">Serviços</a></li>
        <li><a href="/aplicacoes">Aplicações</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/contato#orcamento" class="btn-cta-mobile">Solicitar Orçamento →</a></li>
      </ul>
    </nav>
  </div>
</header>

<style>
  /* ─── Header base ────────────────────────────────────────── */
  .site-header {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    transition:
      background-color var(--dur-short) var(--ease-smooth),
      backdrop-filter var(--dur-short) var(--ease-smooth);
  }

  /* Estado ao scroll: glassmorphism */
  .site-header.is-scrolled {
    position: fixed;
    background-color: rgba(10, 15, 26, 0.9);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(36, 48, 69, 0.5);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    height: 72px;
  }

  /* ─── Logo ───────────────────────────────────────────────── */
  .logo {
    flex-shrink: 0;
    transition: opacity var(--dur-micro) var(--ease-smooth);
  }
  .logo:hover { opacity: 0.85; }

  /* ─── Nav Links ──────────────────────────────────────────── */
  .nav-links {
    display: none;
    list-style: none;
    gap: 0;
  }

  @media (min-width: 1024px) {
    .nav-links { display: flex; align-items: center; }
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 0.5rem 1rem;
    color: var(--steel-300);
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 600;
    transition: color var(--dur-micro) var(--ease-smooth);
    background: none;
    border: none;
    cursor: pointer;
  }

  .nav-link:hover,
  .nav-link:focus-visible {
    color: var(--pure-white);
  }

  .nav-link--dropdown { position: relative; }

  .dropdown-chevron {
    transition: transform var(--dur-micro) var(--ease-mechanical);
  }

  .has-dropdown.is-open .dropdown-chevron {
    transform: rotate(180deg);
  }

  /* ─── Mega Menu ──────────────────────────────────────────── */
  .mega-menu {
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    width: 580px;
    background: var(--steel-900);
    border: 1px solid var(--steel-700);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 24px 48px rgba(0, 0, 0, 0.5);
  }

  .mega-menu-inner { padding: 1.5rem; }

  .mega-menu-featured {
    border-bottom: 1px solid var(--steel-700);
    margin-bottom: 1rem;
    padding-bottom: 1rem;
  }

  .mega-menu-cij {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem;
    border-radius: 6px;
    transition: background-color var(--dur-micro) var(--ease-smooth);
  }
  .mega-menu-cij:hover { background: var(--steel-800); }

  .mega-menu-star {
    color: var(--sj-red);
    font-size: 1.25rem;
    line-height: 1;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .mega-menu-cij strong {
    display: block;
    color: var(--pure-white);
    font-size: 0.9375rem;
    font-weight: 700;
  }

  .mega-menu-models {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--steel-500);
    margin-top: 2px;
  }

  .mega-menu-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.25rem;
  }

  .mega-menu-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 0.625rem 0.75rem;
    border-radius: 6px;
    transition: background-color var(--dur-micro) var(--ease-smooth);
  }
  .mega-menu-item:hover { background: var(--steel-800); }

  .mega-menu-item strong {
    color: var(--pure-white);
    font-size: 0.875rem;
    font-weight: 600;
  }

  .mega-menu-item span {
    color: var(--steel-500);
    font-size: 0.8125rem;
  }

  .mega-menu-item--accent strong { color: var(--sj-red); }

  /* ─── Nav Actions ────────────────────────────────────────── */
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .btn-search {
    color: var(--steel-300);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 4px;
    transition: color var(--dur-micro) var(--ease-smooth);
    display: none;
  }

  @media (min-width: 1024px) {
    .btn-search { display: flex; align-items: center; }
  }

  .btn-search:hover { color: var(--pure-white); }

  .btn-cta {
    display: none;
    align-items: center;
    gap: 0.5rem;
    background: var(--sj-red);
    color: var(--pure-white);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9375rem;
    padding: 0.625rem 1.25rem;
    border-radius: 4px;
    transition:
      background-color var(--dur-micro) var(--ease-mechanical),
      transform var(--dur-micro) var(--ease-mechanical),
      box-shadow var(--dur-micro) var(--ease-mechanical);
  }

  @media (min-width: 768px) {
    .btn-cta { display: inline-flex; }
  }

  .btn-cta:hover {
    background: var(--sj-red-dark);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(204, 26, 26, 0.4);
  }

  .btn-cta:active {
    transform: translateY(0);
  }

  .btn-arrow {
    transition: transform var(--dur-micro) var(--ease-mechanical);
  }
  .btn-cta:hover .btn-arrow { transform: translateX(4px); }

  /* ─── Hamburger ──────────────────────────────────────────── */
  .btn-hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    width: 40px;
    height: 40px;
  }

  @media (min-width: 1024px) {
    .btn-hamburger { display: none; }
  }

  .btn-hamburger span {
    display: block;
    height: 2px;
    background: var(--pure-white);
    border-radius: 1px;
    transition: transform var(--dur-short) var(--ease-mechanical),
                opacity var(--dur-short) var(--ease-mechanical);
  }

  .btn-hamburger[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .btn-hamburger[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }
  .btn-hamburger[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ─── Mobile Menu ────────────────────────────────────────── */
  .mobile-menu {
    display: none;
    position: fixed;
    inset: 0;
    background: var(--steel-950);
    z-index: 99;
    padding: 6rem 1.25rem 2rem;
    overflow-y: auto;
  }

  .mobile-menu.is-open {
    display: block;
  }

  .mobile-menu ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .mobile-menu a {
    display: block;
    color: var(--steel-300);
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    padding: 0.875rem 0;
    border-bottom: 1px solid var(--steel-800);
    transition: color var(--dur-micro) var(--ease-smooth);
  }

  .mobile-menu a:hover { color: var(--pure-white); }

  .btn-cta-mobile {
    color: var(--sj-red) !important;
    border-bottom: none !important;
    font-size: 1.125rem !important;
    margin-top: 1rem;
  }
</style>

<script>
  // ─── Dropdown Mega Menu ───────────────────────────────────
  const dropdownTriggers = document.querySelectorAll('.has-dropdown .nav-link--dropdown');

  dropdownTriggers.forEach((trigger) => {
    const parent = trigger.closest('.has-dropdown');
    const menu = parent?.querySelector('.mega-menu');

    if (!menu) return;

    trigger.addEventListener('click', () => {
      const isOpen = parent.classList.contains('is-open');

      // Fecha todos os outros
      document.querySelectorAll('.has-dropdown.is-open').forEach((el) => {
        el.classList.remove('is-open');
        el.querySelector('.mega-menu')?.classList.remove('is-open');
        el.querySelector('.nav-link--dropdown')?.setAttribute('aria-expanded', 'false');
      });

      if (!isOpen) {
        parent.classList.add('is-open');
        menu.classList.add('is-open');
        trigger.setAttribute('aria-expanded', 'true');
      }
    });
  });

  // Fecha ao clicar fora
  document.addEventListener('click', (e) => {
    if (!e.target.closest('.has-dropdown')) {
      document.querySelectorAll('.has-dropdown.is-open').forEach((el) => {
        el.classList.remove('is-open');
        el.querySelector('.mega-menu')?.classList.remove('is-open');
        el.querySelector('.nav-link--dropdown')?.setAttribute('aria-expanded', 'false');
      });
    }
  });

  // ─── Mobile Menu ─────────────────────────────────────────
  const hamburger = document.querySelector('.btn-hamburger');
  const mobileMenu = document.querySelector('.mobile-menu');

  hamburger?.addEventListener('click', () => {
    const isOpen = hamburger.getAttribute('aria-expanded') === 'true';
    hamburger.setAttribute('aria-expanded', String(!isOpen));
    mobileMenu?.classList.toggle('is-open', !isOpen);
    mobileMenu?.setAttribute('aria-hidden', String(isOpen));
    document.body.style.overflow = isOpen ? '' : 'hidden';
  });
</script>
