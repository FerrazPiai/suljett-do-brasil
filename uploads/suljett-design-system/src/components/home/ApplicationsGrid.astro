---
/**
 * ApplicationsGrid — Setores de aplicação
 * Grid 2x3 com hover expandindo card e revelando CTA.
 */

const applications = [
  {
    sector: 'Alimentícia',
    slug: 'alimenticia',
    description: 'Validade, lote e rastreabilidade em produtos embalados.',
    image: '/assets/applications/alimenticia.jpg',
    alt: 'Impressão de validade em embalagem alimentícia',
  },
  {
    sector: 'Bebidas',
    slug: 'bebidas',
    description: 'Codificação de garrafas, latas e caixas de bebida.',
    image: '/assets/applications/bebidas.jpg',
    alt: 'Impressão em garrafa de bebida na linha de produção',
  },
  {
    sector: 'Laticínios',
    slug: 'laticinios',
    description: 'Marcação em embalagens de leite, iogurte e queijos.',
    image: '/assets/applications/laticinios.jpg',
    alt: 'Impressão em embalagem de laticínio',
  },
  {
    sector: 'Farmacêutica',
    slug: 'farmaceutica',
    description: 'Rastreabilidade e serialização exigidas pela ANVISA.',
    image: '/assets/applications/farmaceutica.jpg',
    alt: 'Impressão em embalagem farmacêutica',
  },
  {
    sector: 'Automotiva',
    slug: 'automotiva',
    description: 'Identificação de peças e componentes em alta velocidade.',
    image: '/assets/applications/automotiva.jpg',
    alt: 'Impressão em peça automotiva',
  },
  {
    sector: 'Ovos',
    slug: 'ovos',
    description: 'Carimbo direto na casca com tinta alimentícia aprovada.',
    image: '/assets/applications/ovos.jpg',
    alt: 'Impressão diretamente na casca de ovos',
  },
];
---

<section
  class="applications section theme-light"
  aria-label="Setores de aplicação da impressora CIJ"
>
  <div class="container">

    <header class="applications-header">
      <span class="spec apps-label">Aplicações Industriais</span>
      <h2 class="apps-title">Solução CIJ para cada setor</h2>
      <p class="apps-subtitle">
        De alimentos a farmacêuticos — a Hitachi CIJ opera com precisão
        em qualquer ambiente industrial.
      </p>
    </header>

    <div class="applications-grid" role="list">
      {applications.map((app) => (
        <article
          class="app-card"
          role="listitem"
          aria-label={`Aplicação para setor ${app.sector}`}
        >
          <!-- Imagem de fundo -->
          <div class="app-card-bg" aria-hidden="true">
            <!-- Placeholder escuro quando sem imagem -->
            <div class="app-card-img-placeholder"></div>
          </div>

          <!-- Overlay gradiente -->
          <div class="app-card-overlay" aria-hidden="true"></div>

          <!-- Conteúdo sempre visível -->
          <div class="app-card-content">
            <h3 class="app-card-sector">{app.sector}</h3>
            <p class="app-card-description">{app.description}</p>

            <!-- CTA: visível no hover -->
            <a
              href={`/aplicacoes/${app.slug}`}
              class="app-card-cta"
              aria-label={`Ver solução CIJ para ${app.sector}`}
            >
              Ver Solução CIJ para {app.sector}
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>

    <div class="applications-footer">
      <a href="/aplicacoes" class="apps-all-link">
        Ver todas as aplicações
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<style>
  /* ─── Header ─────────────────────────────────────────────── */
  .applications-header {
    text-align: center;
    max-width: 560px;
    margin-inline: auto;
    margin-bottom: 3rem;
  }

  .apps-label.spec {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--sj-red);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 0.875rem;
  }

  .apps-title {
    font-size: var(--text-h2);
    font-weight: 700;
    color: var(--ink-950);
    line-height: 1.15;
    margin-bottom: 0.875rem;
  }

  .apps-subtitle {
    color: var(--steel-500);
    font-size: 1.0625rem;
    line-height: 1.6;
  }

  /* ─── Grid ───────────────────────────────────────────────── */
  .applications-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .applications-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .applications-grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* ─── Card ───────────────────────────────────────────────── */
  .app-card {
    position: relative;
    height: 280px;
    border-radius: 4px;
    overflow: hidden;
    cursor: pointer;
  }

  @media (min-width: 768px) {
    .app-card { height: 320px; }
  }

  /* Background */
  .app-card-bg {
    position: absolute;
    inset: 0;
  }

  .app-card-img-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--steel-800), var(--steel-900));
    transition: transform var(--dur-medium) var(--ease-mechanical);
  }

  .app-card:hover .app-card-img-placeholder {
    transform: scale(1.05);
  }

  /* Overlay */
  .app-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(10, 15, 26, 0.92) 0%,
      rgba(10, 15, 26, 0.4) 50%,
      rgba(10, 15, 26, 0.1) 100%
    );
    transition: background var(--dur-short) var(--ease-mechanical);
    z-index: 1;
  }

  .app-card:hover .app-card-overlay {
    background: linear-gradient(
      to top,
      rgba(10, 15, 26, 0.95) 0%,
      rgba(10, 15, 26, 0.7) 60%,
      rgba(10, 15, 26, 0.3) 100%
    );
  }

  /* Conteúdo */
  .app-card-content {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.5rem;
    gap: 0.5rem;
  }

  .app-card-sector {
    font-size: var(--text-h3);
    font-weight: 700;
    color: var(--pure-white);
    line-height: 1.2;
  }

  .app-card-description {
    font-size: 0.875rem;
    color: var(--steel-300);
    line-height: 1.5;
    max-width: 240px;
  }

  /* CTA: surge no hover */
  .app-card-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--sj-red);
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 600;
    margin-top: 0.25rem;
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity var(--dur-short) var(--ease-mechanical),
      transform var(--dur-short) var(--ease-mechanical),
      gap var(--dur-micro) var(--ease-mechanical);
  }

  .app-card:hover .app-card-cta {
    opacity: 1;
    transform: translateY(0);
  }

  .app-card-cta:hover {
    gap: 0.625rem;
  }

  /* Borda de acento no hover */
  .app-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--sj-red);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--dur-short) var(--ease-mechanical);
    z-index: 3;
  }

  .app-card:hover::after {
    transform: scaleX(1);
  }

  /* ─── Footer ─────────────────────────────────────────────── */
  .applications-footer {
    text-align: center;
    margin-top: 2.5rem;
  }

  .apps-all-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--sj-red);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.9375rem;
    transition:
      gap var(--dur-micro) var(--ease-mechanical),
      color var(--dur-micro) var(--ease-mechanical);
  }

  .apps-all-link:hover {
    color: var(--sj-red-dark);
    gap: 0.75rem;
  }
</style>
